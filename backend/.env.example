# ──────────────────────────────────────────────────────────────
# Smart Lab Equipment Booking & Usage Intelligence System
# Environment Variable Template — SAFE TO COMMIT
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and replace all REPLACE_ME values.

# AWS Core
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_ACCOUNT_ID=REPLACE_ME
AWS_REGION=us-east-1

# S3 Buckets
S3_OPERATIONAL_BUCKET=smart-lab-operational
S3_ANALYTICAL_BUCKET=smart-lab-analytical
S3_ASSETS_BUCKET=smart-lab-assets

# DynamoDB Tables
DYNAMO_EQUIPMENT_TABLE=SmartLab-Equipment
DYNAMO_BOOKINGS_TABLE=SmartLab-Bookings
DYNAMO_USERS_TABLE=SmartLab-Users
DYNAMO_AUDITLOGS_TABLE=SmartLab-AuditLogs
DYNAMO_CONNECTIONS_TABLE=SmartLab-WSConnections
DYNAMO_FORECAST_JOBS_TABLE=SmartLab-ForecastJobs
DYNAMO_CHAT_SESSIONS_TABLE=SmartLab-ChatSessions
DYNAMO_USAGE_METRICS_TABLE=SmartLab-UsageMetrics

# Cognito
COGNITO_USER_POOL_ID=REPLACE_ME
COGNITO_CLIENT_ID=REPLACE_ME

# API Gateway
API_GATEWAY_URL=https://REPLACE_ME.execute-api.us-east-1.amazonaws.com/prod
WEBSOCKET_API_URL=wss://REPLACE_ME.execute-api.us-east-1.amazonaws.com/prod

# GenAI
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
OPENAI_API_KEY=REPLACE_ME
BEDROCK_TOKEN_CAP_MONTHLY=100000
TOKEN_ESTIMATE_MULTIPLIER=2

# KMS
KMS_KEY_ID=REPLACE_ME

# Athena
ATHENA_DATABASE=smart_lab_db
ATHENA_WORKGROUP=primary
ATHENA_RESULTS_BUCKET=s3://smart-lab-analytical/athena-results/

# QuickSight (leave blank to use recharts fallback)
QUICKSIGHT_DASHBOARD_ID=REPLACE_ME
QUICKSIGHT_NAMESPACE=default

# SSM
SSM_ROLE_DOMAINS_PATH=/smartlab/role-domains

# CORS — comma-separated allowed origins
ALLOWED_ORIGIN=https://app.university.edu,http://localhost:5173

# Monitoring
ALERT_EMAIL=REPLACE_ME

# App
JWT_SECRET=REPLACE_ME_MUST_BE_AT_LEAST_32_CHARACTERS_LONG
NODE_ENV=development
PORT=4000
